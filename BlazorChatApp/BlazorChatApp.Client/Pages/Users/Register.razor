@page "/register"
@using System.ComponentModel.DataAnnotations
@using System.Text.RegularExpressions
@using BlazorChatApp.Application.DTOs
@using BlazorChatApp.Application.DTOs.Users
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Class="pa-6" Elevation="3">
        <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true">
            Create Account
        </MudText>

        @if (isLoading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-4" />
        }
        else
        {
            <EditForm Model="@model" OnSubmit="HandleSubmit">
                <DataAnnotationsValidator />

                <MudGrid Class="mt-4">
                    <MudItem xs="12">
                        <MudTextField @bind-Value="model.UserName"
                                      Label="Username"
                                      Variant="Variant.Outlined"
                                      Required="true"
                                      RequiredError="Username is required" />
                        <ValidationMessage For="@(() => model.UserName)" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudTextField @bind-Value="model.Email"
                                      Label="Email"
                                      Variant="Variant.Outlined"
                                      Required="true"
                                      RequiredError="Email is required" />
                        <ValidationMessage For="@(() => model.Email)" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudTextField @bind-Value="model.Password"
                                      Label="Password"
                                      Variant="Variant.Outlined"
                                      InputType="@passwordInputType"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@passwordIcon"
                                      OnAdornmentClick="TogglePasswordVisibility"
                                      AdornmentAriaLabel="Show Password"
                                      Required="true"
                                      RequiredError="Password is required"
                                      HelperText="Minimum 6 characters" />
                        <ValidationMessage For="@(() => model.Password)" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudTextField @bind-Value="model.PasswordAgain"
                                      Label="Confirm Password"
                                      Variant="Variant.Outlined"
                                      InputType="@confirmPasswordInputType"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@confirmPasswordIcon"
                                      OnAdornmentClick="ToggleConfirmPasswordVisibility"
                                      AdornmentAriaLabel="Show Confirm Password"
                                      Required="true"
                                      RequiredError="Please confirm your password" />
                        <ValidationMessage For="@(() => model.PasswordAgain)" />
                    </MudItem>

                    @if (!string.IsNullOrEmpty(successMessage))
                    {
                        <MudItem xs="12">
                            <MudAlert Severity="Severity.Success" Variant="Variant.Filled">
                                @successMessage
                            </MudAlert>
                        </MudItem>
                    }

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <MudItem xs="12">
                            <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
                                @errorMessage
                            </MudAlert>
                        </MudItem>
                    }

                    <MudItem xs="12">
                        <MudText Align="Align.Center" Typo="Typo.body2">
                            Already have an account? <MudLink Href="/login">Click here to login.</MudLink>
                        </MudText>
                    </MudItem>

                    <MudItem xs="12" Class="d-flex justify-center">
                        <MudButton ButtonType="ButtonType.Submit"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   Disabled="isSubmitting"
                                   Size="Size.Large">
                            @if (isSubmitting)
                            {
                                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                                <MudText Class="ms-2">Creating account...</MudText>
                            }
                            else
                            {
                                <MudText>Register</MudText>
                            }
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </EditForm>
        }
    </MudPaper>
</MudContainer>

@code {
    UserRegisterDTO model = new UserRegisterDTO();

    private ValidationMessageStore? _messageStore;

    private bool isLoading = false;
    private bool isSubmitting = false;
    private string? successMessage;
    private string? errorMessage;

    private bool showPassword = false;
    private bool showConfirmPassword = false;

    private InputType passwordInputType => showPassword ? InputType.Text : InputType.Password;
    private InputType confirmPasswordInputType => showConfirmPassword ? InputType.Text : InputType.Password;

    private string passwordIcon => showPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;
    private string confirmPasswordIcon => showConfirmPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;

    private void TogglePasswordVisibility() => showPassword = !showPassword;
    private void ToggleConfirmPasswordVisibility() => showConfirmPassword = !showConfirmPassword;

    [JSInvokable]
    private async void HandleSubmit(EditContext context)
    {
        try
        {
            isSubmitting = true;
            successMessage = null;
            errorMessage = null;
            StateHasChanged();

            _messageStore ??= new ValidationMessageStore(context);
            _messageStore.Clear();
            context.NotifyValidationStateChanged();

            HttpResponseWrapper? httpResponseWrapper = null;
            var targetUrl = "/api/user/register";

            try
            {
                //Reason for using JSInterop:
                //Blazor servermode cannot work with cookies from httpClient requests.

                httpResponseWrapper = await JSRuntime.InvokeAsync<HttpResponseWrapper>("eval",
                $$"""
                    (async function() {

                        var formData = new FormData();
                        formData.append('Email', '{{model.Email}}');
                        formData.append('Password', '{{model.Password}}');
                        formData.append('UserName', '{{model.UserName}}');
                        formData.append('PasswordAgain', '{{model.PasswordAgain}}');

                        const response = await fetch('{{targetUrl}}', {
                            method: 'POST',
                            body: formData
                        });

                        if (!response.ok) {
                            const errorData = await response.json();
                            return { Message: errorData.message, StatusCode: response.status };
                        }

                       return { Message: 'Registration successful', StatusCode: response.status };
                    })();
                """
                );

            }
            catch (Exception)
            {
                errorMessage = "An unexpected error occurred. Please try again.";
            }

            if (httpResponseWrapper?.StatusCode == 200)
            {
                Navigation.NavigateTo("/", forceLoad: true);
            }
            else if (httpResponseWrapper?.Message is not null)
            {
                AssignErrorToField(httpResponseWrapper.Message, _messageStore);
                context.NotifyValidationStateChanged();
            }
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }

    private void AssignErrorToField(string errorMessage, ValidationMessageStore messageStore)
    {
        var lowerError = errorMessage.ToLower();

        if (lowerError.Contains("username"))
        {
            messageStore.Add(() => model.UserName, errorMessage);        }

        if (lowerError.Contains("email") || lowerError.Contains("e-mail"))
        {
            messageStore.Add(() => model.Email, errorMessage);
        }

        if (lowerError.Contains("password") && !lowerError.Contains("confirm") && !lowerError.Contains("match"))
        {
            messageStore.Add(() => model.Password, errorMessage);
        }

        if (lowerError.Contains("match") || lowerError.Contains("confirm"))
        {
            messageStore.Add(() => model.PasswordAgain, errorMessage);
        }
        this.errorMessage = errorMessage;
    }

    private class HttpResponseWrapper
    {
        public string? Message { get; set; }
        public int StatusCode { get; set; }
    }
}