@page "/login"
@using System.ComponentModel.DataAnnotations
@using System.Text.RegularExpressions
@using BlazorChatApp.Application.DTOs
@using BlazorChatApp.Application.DTOs.Users
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Class="pa-6" Elevation="3">
        <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true">
            Login
        </MudText>

        @if (isLoading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-4" />
        }
        else
        {
            <EditForm Model="@model" OnSubmit="HandleSubmit">
                <DataAnnotationsValidator />

                <MudGrid Class="mt-4">
                    <MudItem xs="12">
                        <MudTextField @bind-Value="model.Email"
                                      Label="Email"
                                      Variant="Variant.Outlined"
                                      Required="true"
                                      RequiredError="Email is required" />
                        <ValidationMessage For="@(() => model.Email)" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudTextField @bind-Value="model.Password"
                                      Label="Password"
                                      Variant="Variant.Outlined"
                                      InputType="@passwordInputType"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@passwordIcon"
                                      OnAdornmentClick="TogglePasswordVisibility"
                                      AdornmentAriaLabel="Show Password"
                                      Required="true"
                                      RequiredError="Password is required" />
                        <ValidationMessage For="@(() => model.Password)" />
                    </MudItem>

                    @if (!string.IsNullOrEmpty(successMessage))
                    {
                        <MudItem xs="12">
                            <MudAlert Severity="Severity.Success" Variant="Variant.Filled">
                                @successMessage
                            </MudAlert>
                        </MudItem>
                    }

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <MudItem xs="12">
                            <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
                                @errorMessage
                            </MudAlert>
                        </MudItem>
                    }

                    <MudItem xs="12">
                        <MudText Align="Align.Center" Typo="Typo.body2">
                            Don't have an account? <MudLink Href="/register">Click here to register.</MudLink>
                        </MudText>
                    </MudItem>

                    <MudItem xs="12" Class="d-flex justify-center">
                        <MudButton ButtonType="ButtonType.Submit"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   Disabled="isSubmitting"
                                   Size="Size.Large">
                            @if (isSubmitting)
                            {
                                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                                <MudText Class="ms-2">Logging in...</MudText>
                            }
                            else
                            {
                                <MudText>Login</MudText>
                            }
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </EditForm>
        }
    </MudPaper>
</MudContainer>

@code {
    UserLoginDTO model = new UserLoginDTO();

    private ValidationMessageStore? _messageStore;
    
    private bool isLoading = false;
    private bool isSubmitting = false;
    private string? successMessage;
    private string? errorMessage;

    private bool showPassword = false;
    private InputType passwordInputType => showPassword ? InputType.Text : InputType.Password;
    private string passwordIcon => showPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;

    private void TogglePasswordVisibility() => showPassword = !showPassword;

    [JSInvokable]
    private async void HandleSubmit(EditContext context)
    {
        try
        {
            isSubmitting = true;
            successMessage = null;
            errorMessage = null;
            StateHasChanged();

            _messageStore ??= new ValidationMessageStore(context);
            _messageStore.Clear();
            context.NotifyValidationStateChanged();

            HttpResponseWrapper? httpResponseWrapper = null;
            var targetUrl = "/api/user/login";

            try
            {
                //Reason for using JSInterop:
                //Blazor servermode cannot work with cookies from httpClient requests.

                httpResponseWrapper = await JSRuntime.InvokeAsync<HttpResponseWrapper>("eval",
                $$"""
                    (async function() {

                        var formData = new FormData();
                        formData.append('Email', '{{model.Email}}');
                        formData.append('Password', '{{model.Password}}');

                        const response = await fetch('{{targetUrl}}', {
                            method: 'POST',
                            body: formData
                        });

                        if (!response.ok) {
                            const errorData = await response.json();
                            return { Message: errorData.message, StatusCode: response.status };
                        }

                       return { Message: 'Login successful', StatusCode: response.status };
                    })();
                """
                );

            }
            catch (Exception)
            {
                errorMessage = "An unexpected error occurred. Please try again.";
                _messageStore.Add(() => model.Email, "An unexpected error occurred.");
            }

            if (httpResponseWrapper?.StatusCode == 200)
            {
                Navigation.NavigateTo("/", forceLoad: true);
            }
            else if (httpResponseWrapper?.Message is not null)
            {
                if (httpResponseWrapper.Message == "Invalid password")
                {
                    errorMessage = "Invalid password. Please try again.";
                    _messageStore.Add(() => model.Password, httpResponseWrapper.Message);
                }

                if (httpResponseWrapper.Message == "User not found")
                {
                    errorMessage = "User not found. Please check your email.";
                    _messageStore.Add(() => model.Email, httpResponseWrapper.Message);
                }
            }

            context.NotifyValidationStateChanged();
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }

    private class HttpResponseWrapper
    {
        public string? Message { get; set; }
        public int StatusCode { get; set; }
    }
}